# このファイルを .env.local としてコピーし、値を埋めてください。
# .env.local は .gitignore 済みで、コミット・pushされません。
# ここで設定した値は npm run dev (ローカル実行) でのみ有効で、
# GitHub Actions側にはこの環境変数を設定していないため、本番の公開サイトには含まれません。

# GitHubのユーザー名
NEXT_PUBLIC_GITHUB_OWNER=nagi3x9

# リポジトリ名
NEXT_PUBLIC_GITHUB_REPO=GitHubPage-SEO

# 対象ブランチ(通常はmain)
NEXT_PUBLIC_GITHUB_BRANCH=main

# GitHubのFine-grained Personal Access Token
# 発行方法: GitHub右上のアイコン → Settings → Developer settings
#   → Personal access tokens → Fine-grained tokens → Generate new token
#   - Repository access: Only select repositories → GitHubPage-SEO のみ選択
#   - Permissions → Repository permissions → Contents: Read and write
#   - Expiration: 検証が終わったら失効するよう短め(例: 7日)に設定推奨
# 発行したトークンはこの行にそのまま貼り付けてください(このファイルはpushされません)
NEXT_PUBLIC_GITHUB_TOKEN=
